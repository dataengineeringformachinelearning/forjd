# Unified forjd-engine (process + data plane)
PORT=8080
RUST_LOG=info
ENGINE_API_TOKEN=

# Data plane role: unset|engine|none|all|relay|scheduler|probe|normalizer|ingest|cpe
# Prefer engine locally until DB/Redis/internode are configured.
FORJD_ROLE=engine

# Required when FORJD_ROLE is active (not engine/none)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forjd
# or POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/forjd
REDIS_URL=redis://:forjd-dev-local@127.0.0.1:6379/0

# Production / Fly
# FORJD_ENV=production
# FORJD_TRANSPORT_SECURITY=required
#
# Bus roles (relay/scheduler/normalizer/all) REQUIRE internode encryption on Fly:
# FORJD_INTERNODE_ENCRYPTION=required
# FORJD_INTERNODE_ACTIVE_KID=v1
# FORJD_INTERNODE_KEYS={"v1":"<base64url-encoded-32-byte-key>"}
# Mint via: openssl rand 32 | openssl base64 -A | tr '+/' '-_' | tr -d '='
# Or: ./scripts/sync_engine_dataplane_secrets.sh
#
# CPE_REDIS_URL=  # only for FORJD_ROLE=cpe
