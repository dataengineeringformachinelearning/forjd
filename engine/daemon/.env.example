# Exactly one production role per service: relay, scheduler, probe, normalizer, ingest, cpe.
FORJD_ROLE=relay
# Prefer DATABASE_URL; POSTGRES_DSN (asyncpg style) is also accepted.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forjd?sslmode=prefer
PORT=8080
STRUCTURED_LOGS=true
RUST_LOG=forjd_daemon=info,warn

# Dragonfly (Compose local or Fly *.internal) — bus for relay/scheduler/normalizer
REDIS_URL=redis://:forjd-dev-local@localhost:6379/0

# Transport + authenticated durable-message encryption (production: required).
FORJD_TRANSPORT_SECURITY=required
FORJD_INTERNODE_ENCRYPTION=disabled
FORJD_INTERNODE_ACTIVE_KID=
FORJD_INTERNODE_KEYS={}
FORJD_NODE_ID=forjd-relay

# relay
BATCH_SIZE=100
POLL_INTERVAL_SECS=1
MAX_ATTEMPTS=5
MAX_CONCURRENCY=64

# probe
PINGER_INTERVAL_SECS=30
HEALTH_PINGER_SKIP_TLS_VERIFY=false

# normalizer
NORMALIZER_GROUP_ID=forjd-telemetry-normalizer-v1

# ingest / cpe
# REDIS_SSL_CA_B64=base64-of-dragonfly-ca-pem
# CPE_REDIS_URL=redis://:forjd-dev-local@localhost:6379/8

# optional Prefect (scheduler may publish task triggers for Python workers)
PREFECT_API_URL=http://127.0.0.1:4200/api

# optional OTLP/HTTP exporter
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.net
# OTEL_SERVICE_NAME=forjd-relay
