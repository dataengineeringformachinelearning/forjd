# App
PROJECT_NAME=forjd
PROJECT_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS (JSON list) — include Angular :4200 locally; production UI is https://forjd.co
CORS_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200","http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173","https://forjd.co"]

# Optional API key for mutating /api/v1 routes (empty = disabled for local PoC).
# Use X-API-Key. Bearer JWTs are for Supabase Auth (not this shared secret).
API_KEY=

# Supabase Auth (JWT). Prefer JWKS via SUPABASE_URL; HS256 secret is a fallback.
# Enterprise humans: Bearer <user access_token>.
# Subprocessors (partner SaaS): Bearer fjsvc_<prefix>_<secret> (sql/014) or a
# Supabase user JWT with app_metadata.forjd.principal_type=service.
# See backend/docs/AUTH.md — never send partner end-user tokens here.
# Apply sql/003–025 for E2EE ingest, projections, SIEM/SOAR, exports, and recovery.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_AUTH_REQUIRED=false
# Frontend also needs the public anon key in environment*.ts (never the service role).

# Configurable workflows (YAML/JSON). Relative to backend cwd (Docker WORKDIR=/app).
WORKFLOWS_DIR=workflows

# Zero-trust schema / crypto (production ENVIRONMENT forces fail-closed):
# SOFT_MIGRATE_SCHEMA=false, REQUIRE_RLS=true, REQUIRE_CRYPTO_SESSION=true
SOFT_MIGRATE_SCHEMA=true
REQUIRE_RLS=false
REQUIRE_CRYPTO_SESSION=false
# Optional background projection catch-up (0 = off). Live ingest already advances watermarks.
PROJECTION_TICK_SECONDS=0

# Sealed-stream metadata anomaly defaults (workflow YAML overrides these)
STREAM_ANOMALY_ZSCORE=2.5
STREAM_ANOMALY_MAX_CIPHER_LEN=262144

# Database — Supabase Postgres only (do not point FORJD at Neon).
# Pooler (app): postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Direct (migrations / pg_restore): postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres
# Neon→Supabase consolidation: docs/NEON_TO_SUPABASE.md
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/forjd

# Cache — local Compose Dragonfly (password matches compose DFLY_PASSWORD), or Fly private URL
# Local: redis://:forjd-dev-local@localhost:6379/0
# Fly:   redis://:PASSWORD@forjd-dragonfly.internal:6379/0
REDIS_URL=redis://:forjd-dev-local@localhost:6379/0

# Prefect
PREFECT_API_URL=http://127.0.0.1:4200/api

# Rust engine — empty uses in-process PyO3; set for Compose/Fly HTTP
# Local Compose engine service: http://127.0.0.1:8080
# Fly private: http://forjd-engine.internal:8080
ENGINE_URL=
ENGINE_API_TOKEN=
ENGINE_TIMEOUT_SECONDS=10

# Rollbar (post_server_item token). Empty = disabled.
ROLLBAR_ACCESS_TOKEN=
ROLLBAR_ENVIRONMENT=production

# Sentry error tracking. Empty DSN = disabled. Install: uv sync --group sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=
RATE_LIMIT_ENABLED=true
READ_RATE_LIMIT_RPM=1200
WRITE_RATE_LIMIT_RPM=300
INGEST_RATE_LIMIT_RPM=120
PUBLIC_RATE_LIMIT_RPM=120
AUTH_FAILURE_RATE_LIMIT_RPM=60
SENTRY_TRACES_SAMPLE_RATE=0.0

# Add-ons (optional integrations; disabled by default). Comma-separated slugs
# or "all" to enable the whole catalog. See GET /api/v1/addons.
# Slugs: osv-dev, osv-scanner, osv-scalibr, nuclei, honeydb, go-cve-dictionary,
#        jax, acme, robotframework, oss-fuzz, design-patterns-python
FORJD_ADDONS=
# Used only when FORJD_ADDONS is empty. Example: config/addons/deml.yaml
FORJD_ADDONS_CONFIG=
# Add-on service config (used only when the matching add-on is enabled)
OSV_API_URL=https://api.osv.dev
HONEYDB_API_ID=
HONEYDB_API_KEY=
GO_CVE_DICTIONARY_URL=

# Optional ML catalog (/api/v1/ml) — install with: uv sync --group ml
ML_SEQ_LEN=16
ML_LATENT_DIM=16
ML_HIDDEN_DIM=32
ML_EPOCHS=40
ML_ANOMALY_THRESHOLD=0.15
ML_MODEL_DIR=data/models
ML_MODEL_VERSION=lstm-ae-v1

# Domain scanners (optional — empty disables remote calls)
PAGESPEED_API_KEY=
HIBP_API_KEY=
TOR_PROXY_URL=
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev
SCANNER_SERVICE_URL=
# Production custom TAXII/webhook egress fails closed when empty. Use exact
# hosts or explicit subdomain rules; `*.hooks.example.com` does not match the
# apex or `evilhooks.example.com`. Never include schemes, paths, or credentials.
OUTBOUND_HOST_ALLOWLIST=
# Optional HMAC webhook keys, keyed by the safe ``secret_ref`` stored in a
# playbook. Keep the JSON value in the deployment secret manager, not source.
WEBHOOK_SIGNING_SECRETS_JSON=

# S3-compatible object storage for exports/reports (empty = local data/exports|reports)
# uv sync --group storage
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_BUCKET=forjd-exports
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ADDRESSING_STYLE=path
EXPORT_WORKER_INTERVAL_SECONDS=2
EXPORT_MAX_ATTEMPTS=5
EXPORT_TTL_SECONDS=604800
EXPORT_MAX_ARTIFACT_BYTES=104857600
# Bounds in-process source materialization; raise only on dedicated workers with measured memory.
EXPORT_MAX_SOURCE_BYTES=67108864

# Durable data-plane worker tuning (safe across multiple API replicas)
INGEST_PROCESSING_INTERVAL_SECONDS=2
INGEST_PROCESSING_BATCH_SIZE=10
SOAR_WORKER_INTERVAL_SECONDS=5
SOAR_WORKER_BATCH_SIZE=50

# Continuous analytics rollups + classical ML refresh (0 disables the worker)
ANALYTICS_ROLLUP_INTERVAL_SECONDS=300
ANALYTICS_ML_REFRESH_SECONDS=3600

# Scheduled ML training (0 tick disables) + optional Hugging Face publishing.
# Set both HF_* values to publish fresh .pt artifacts (hashed tenant paths).
TRAINING_TICK_SECONDS=3600
TRAINING_REFRESH_SECONDS=86400
HF_MODEL_REPO_ID=
HF_TOKEN=

# Data retention sweep (0 interval disables; bounded batch deletes).
# 30-day default is the platform compliance promise ("30-Day Retention").
RETENTION_SWEEP_INTERVAL_SECONDS=3600
RETENTION_TELEMETRY_DAYS=30
RETENTION_RESULTS_DAYS=30
RETENTION_RECEIPTS_DAYS=30
