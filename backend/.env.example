# App
PROJECT_NAME=forjd
PROJECT_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS (JSON list) — include Angular :4200 locally; production UI is https://forjd.co
CORS_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200","http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173","https://forjd.co"]

# Optional API key for mutating /api/v1 routes (empty = disabled for local PoC)
API_KEY=

# Database — Supabase Postgres (Transaction / Session pooler DSN)
# Format: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or direct: postgresql+asyncpg://postgres:[password]@db.[ref].supabase.co:5432/postgres
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/forjd

# Cache — local Compose Dragonfly (password matches compose DFLY_PASSWORD), or Fly private URL
# Local: redis://:forjd-dev-local@localhost:6379/0
# Fly:   redis://:PASSWORD@forjd-dragonfly.internal:6379/0
REDIS_URL=redis://:forjd-dev-local@localhost:6379/0

# Prefect
PREFECT_API_URL=http://127.0.0.1:4200/api

# Rust engine — empty uses in-process PyO3; set for Compose/Fly HTTP
# Local Compose engine service: http://127.0.0.1:8080
# Fly private: http://forjd-engine.internal:8080
ENGINE_URL=
ENGINE_API_TOKEN=
ENGINE_TIMEOUT_SECONDS=10

# Rollbar (post_server_item token). Empty = disabled.
ROLLBAR_ACCESS_TOKEN=

# Unsupervised ML PoC (LSTM-Autoencoder + Supabase pgvector)
# Install: uv sync --group ml   then run sql/002_anomaly_embeddings.sql in Supabase
ML_SEQ_LEN=16
ML_LATENT_DIM=16
ML_HIDDEN_DIM=32
ML_EPOCHS=40
ML_ANOMALY_THRESHOLD=0.15
ML_MODEL_DIR=data/models
ML_MODEL_VERSION=lstm-ae-v1
