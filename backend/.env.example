# App
PROJECT_NAME=forjd
PROJECT_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS (JSON list) — include Angular default :4200
CORS_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200","http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]

# Database & cache
# Host runs (uv run / local): use localhost
# Docker Compose overrides these to postgres / dragonfly / prefect-server
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/forjd
REDIS_URL=redis://localhost:6379/0

# Prefect
PREFECT_API_URL=http://127.0.0.1:4200/api
